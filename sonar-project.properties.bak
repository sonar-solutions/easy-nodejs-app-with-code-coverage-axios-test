sonar.projectVersion=v1.0.1
sonar.projectKey=sonar-solutions_easy-nodejs-app-with-code-coverage
sonar.organization=sonar-solutions
sonar.host.url=https://sonarcloud.io
sonar.qualitygate.wait=true
sonar.sources=src,risky_code,scripts
sonar.tests=src
sonar.test.inclusions=**/*.test.js
sonar.javascript.lcov.reportPaths=coverage/lcov.info
sonar.javascript.node.maxspace=4096
sonar.plugins.downloadOnlyRequired=true
